# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic API key for Claude AI agent (recommended)
ANTHROPIC_API_KEY=

# Optional: LLM endpoint (OpenAI-compatible, e.g. llama-server — legacy fallback)
LLM_URL=http://localhost:8080/v1

# Optional: Discord bot (from Discord Developer Portal)
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# Optional: Port overrides
WEB_PORT=3000
MCP_PORT=3001

# Network: "testnet" (default) or "mainnet"
ALEO_NETWORK=testnet

# Required if ALEO_NETWORK=mainnet (safety gate)
# MAINNET_CONFIRM=true

# Optional: override default priority fee (in Aleo credits)
# PRIORITY_FEE=0.05

# Gemini API key for voice agent (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Google OAuth (zkLogin) — get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Salt for commitment derivation (change per deployment)
GOOGLE_ZKLOGIN_SALT=ghost_zklogin_v1
